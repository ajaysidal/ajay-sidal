# --- Site ---
NEXT_PUBLIC_SITE_URL=https://www.buildwithai.digital
NEXT_PUBLIC_BRAND_NAME="BUILD WITH AI"

# --- NextAuth ---
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=https://www.buildwithai.digital

# --- OpenProvider ---
# Optional override for sandbox/OTE testing.
# Examples:
# - https://api.openprovider.eu/v1beta/
# - https://api-ote.openprovider.eu/v1beta/
OPENPROVIDER_BASE_URL=
OPENPROVIDER_USERNAME=
OPENPROVIDER_PASSWORD=

# --- Stripe ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# --- Database (Durable store) ---
# Used for durable alpha list + counters in hosted environments.
# For PostgreSQL with SSL (required for production):
# Example: postgresql://user:password@host:port/database?sslmode=verify-full
# Note: sslmode=verify-full is required for secure connections
DATABASE_URL=

# --- Admin ---
# Internal admin secret for admin dashboard access
ADMIN_SECRET=

# --- Cron / Worker auth (Hosted Cron Jobs) ---
# If CRON_SECRET is set, hosted cron invocations should call endpoints with:
#   Authorization: Bearer $CRON_SECRET
# Our worker endpoint (/api/jobs/process) accepts CRON_SECRET (preferred) or JOB_SECRET (legacy).
CRON_SECRET=
JOB_SECRET=

# --- Plesk License Upsell (OpenProvider) ---
# Reseller cost for the default Plesk item (monthly). Used to compute customer price via LICENSE markup (15%).
PLESK_DEFAULT_RESELLER_PRICE=
PLESK_DEFAULT_CURRENCY=USD
PLESK_DEFAULT_ITEM=PLESK-12-VPS-WEB-HOST-1M

# --- MARZ AI Assistant (Upstash Vector) ---
# Create a free vector database at https://upstash.com
# Used for semantic search in MARZ chat
UPSTASH_VECTOR_REST_URL=
UPSTASH_VECTOR_REST_TOKEN=

# --- MARZ LLM (Groq) ---
# Get free API key at https://console.groq.com
# Used for Llama 3 powered responses
GROQ_API_KEY=

# --- OAuth Providers (Optional) ---
# GitHub OAuth for user sign-in
# Create at: https://github.com/settings/developers
GITHUB_ID=
GITHUB_SECRET=

# Google OAuth for user sign-in
# Create at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Monitoring & Logging ---
# Sentry for error tracking (optional)
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# Logging level (debug, info, warn, error)
LOG_LEVEL=info

# Log file path (optional, for production)
LOG_FILE=

# --- Redis Cache (optional) ---
# Used for caching and real-time features
REDIS_URL=

# --- Rate Limiting ---
# Optional rate limiting configuration
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# --- Monetization (MARZ Network) ---
# Alchemy API for Polygon Mainnet (get free key at https://dashboard.alchemy.com)
# ⚠️ IMPORTANT: Enable these 8 services in your Alchemy app:
# 1. Node API (required)
# 2. Smart Wallets (Account Abstraction)
# 3. Bundler API (for smart wallets)
# 4. Gas Manager (sponsor user transactions)
# 5. Token API (token balances)
# 6. Prices API (real-time USD prices)
# 7. Transfers API (transaction history)
# 8. Webhooks (treasury monitoring)
ALCHEMY_API_KEY=your_alchemy_api_key_here
ALCHEMY_POLYGON_RPC=https://polygon-mainnet.g.alchemy.com/v2/your_api_key
NEXT_PUBLIC_ALCHEMY_API_KEY=your_public_api_key

# Treasury Wallet Addresses (Polygon Mainnet)
# Deploy Gnosis Safe at: https://app.safe.global
TREASURY_SAFE_ADDRESS=
TREASURY_HOT_WALLET=

# --- Email (Resend for transactional emails) ---
RESEND_API_KEY=
