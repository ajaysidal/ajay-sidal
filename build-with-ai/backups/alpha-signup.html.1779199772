<!doctype html><html lang="en"><head><meta charset="utf-8"/><meta name="viewport" content="width=device-width,initial-scale=1"/><title>Alpha Signup</title><link rel="icon" href="/favicon.ico"/><style>body{font-family:Inter,system-ui,Arial;margin:40px;color:#071029}</style></head><body><h1>Alpha Program</h1><p>Apply for the alpha program to get early access to integrations, priority support, and direct product influence.</p><form id="alpha" onsubmit="return submitAlpha(event)"><input id="aemail" placeholder="work@company.com" required style="width:100%;padding:8px"/><br/><button type="submit">Apply</button></form><script>async function submitAlpha(e){e.preventDefault();const email=document.getElementById('aemail').value;await fetch('/api/launching-soon/subscribe',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({email,alpha:true})});alert('Thanks — we will review your application.');}</script></body></html>
