<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Launching Soon</title>

  <!-- Google Analytics 4 - replace G-XXXXXXX with your measurement id -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-XXXXXXX"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-XXXXXXX');
  </script>

  <style>
    body { font-family: Inter, system-ui, -apple-system, "Segoe UI", Roboto, "Helvetica Neue", Arial; display:flex; align-items:center; justify-content:center; min-height:100vh; margin:0; background:#f7fafc; }
    .card { background:#fff; padding:28px; border-radius:12px; box-shadow:0 6px 24px rgba(15,23,42,0.08); max-width:520px; width:100%; text-align:center; }
    input[type="email"]{ padding:12px 14px; width:70%; border:1px solid #e6e9ef; border-radius:8px; margin-right:8px; }
    button{ padding:12px 16px; border-radius:8px; border:none; background:#0ea5a4; color:#fff; cursor:pointer; }
    .note{ margin-top:12px; color:#6b7280; font-size:13px; }
  </style>
</head>
<body>
  <div class="card">
    <h1>We are launching soon</h1>
    <p>Join the waitlist to get early access and updates.</p>

    <form id="subscribeForm" onsubmit="return submitForm(event)">
      <input id="email" type="email" placeholder="you@company.com" required />
      <button type="submit">Join Waitlist</button>
    </form>

    <div id="msg" class="note" aria-live="polite"></div>

    <script>
      async function submitForm(e) {
        e.preventDefault();
        const email = document.getElementById('email').value;
        const msg = document.getElementById('msg');
        msg.textContent = 'Saving...';
        try {
          const res = await fetch('/api/launching-soon/subscribe', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ email })
          });
          const j = await res.json();
          if (j.ok) {
            msg.textContent = 'Thanks — you are on the list!';
            document.getElementById('email').value = '';
            if (window.gtag) gtag('event', 'subscribe', { method: 'launching-soon' });
          } else {
            msg.textContent = 'Could not save email. Try again.';
          }
        } catch (err) {
          msg.textContent = 'Network error. Try again later.';
        }
        return false;
      }
    </script>
  </div>
</body>
</html>
