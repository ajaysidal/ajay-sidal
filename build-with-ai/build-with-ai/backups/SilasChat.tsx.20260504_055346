  { id: 'onboard',  label: 'Mint My Identity',   icon: '⬡', desc: 'Claim your MARZ sovereign identity' },
  { id: 'diagnose', label: 'Domain / SSL Check',  icon: '◎', desc: 'Live OpenProvider diagnostics' },
