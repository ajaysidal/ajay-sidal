import { useState, useRef, useEffect } from 'react';

// ─── Types ────────────────────────────────────────────────────────────────────
type WizardMode = 'home' | 'onboard' | 'diagnose' | 'convert' | 'report' | 'chat';

interface LeadForm {
  name: string;
  email: string;
  company: string;
  interest: string;
}

interface DiagnoseResult {
  domain: string;
  available: boolean | null;
  sslStatus: string;
  loading: boolean;
  error: string | null;
}

// ─── Constants ────────────────────────────────────────────────────────────────
