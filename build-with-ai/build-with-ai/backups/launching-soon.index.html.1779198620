<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Build With AI — Enterprise Dev OS</title>
  <meta name="description" content="Sovereign AI-native infrastructure for Web2 and Web3 teams. Enterprise-grade security, on-chain identity, and developer velocity." />
  <meta name="robots" content="index,follow" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <style>
    :root{--bg:#071029;--accent:#06b6d4;--muted:#94a3b8;--glass:rgba(255,255,255,0.04)}
    *{box-sizing:border-box}
    html,body{height:100%;margin:0;font-family:Inter,system-ui,-apple-system,Segoe UI,Roboto,"Helvetica Neue",Arial;color:#fff;background:linear-gradient(180deg,#071029 0%, #071a2a 60%);}
    .wrap{min-height:100vh;display:flex;align-items:center;justify-content:center;padding:48px}
    .grid{width:100%;max-width:1200px;display:grid;grid-template-columns:1fr 420px;gap:40px;align-items:center}
    .brand{font-weight:700;letter-spacing:0.6px}
    h1{font-size:clamp(28px,5vw,48px);margin:0 0 12px}
    p.lead{color:var(--muted);margin:0 0 20px;font-size:18px;max-width:720px}
    .cta-row{display:flex;gap:12px;align-items:center;margin-bottom:18px}
    .btn-primary{background:var(--accent);color:#042027;padding:12px 18px;border-radius:10px;border:none;font-weight:700;cursor:pointer}
    .btn-ghost{background:transparent;border:1px solid rgba(255,255,255,0.08);padding:12px 18px;border-radius:10px;color:var(--muted);cursor:pointer}
    .panel{background:var(--glass);padding:28px;border-radius:14px;backdrop-filter:blur(6px);box-shadow:0 10px 30px rgba(2,6,23,0.6)}
    .features{display:flex;gap:12px;margin-top:18px}
    .feature{flex:1;padding:14px;border-radius:10px;background:rgba(255,255,255,0.02)}
    .feature h4{margin:0 0 6px;font-size:15px}
    .trust{display:flex;gap:12px;align-items:center;margin-top:18px}
    .trust img{height:28px;opacity:0.9}
    form input[type="email"], form select{width:100%;padding:12px;border-radius:10px;border:1px solid rgba(255,255,255,0.06);background:transparent;color:#fff;margin-bottom:12px}
    .muted{color:var(--muted);font-size:13px}
    @media (max-width:900px){ .grid{grid-template-columns:1fr} .panel{order:2} }
  </style>

  <!-- Umami placeholder: replace UMAMI_HOST and UMAMI_WEBSITE_ID -->
  <script async defer src="http://UMAMI_HOST:3001/umami.js"></script>
  <script>window.umami && umami('create','UMAMI_WEBSITE_ID',{autoTrack:true});</script>
</head>
<body>
  <main class="wrap" role="main">
    <div class="grid" aria-labelledby="hero-title">
      <section>
        <div class="brand">BUILD WITH AI</div>
        <h1 id="hero-title">Sovereign AI Infrastructure for Enterprise Dev Teams</h1>
        <p class="lead">Ship AI‑native features faster with built‑in on‑chain identity, enterprise governance, and gasless operations. Trusted by private beta partners.</p>

        <div class="cta-row">
          <a class="btn-primary" href="DEMO_LINK">Request Enterprise Demo</a>
          <button class="btn-ghost" id="join-waitlist">Join Waitlist</button>
        </div>

        <div class="features" aria-hidden="true">
          <div class="feature"><h4>Enterprise Security</h4><div class="muted">Zero vendor lock‑in, RBAC, and auditable on‑chain trails.</div></div>
          <div class="feature"><h4>Developer Velocity</h4><div class="muted">Prebuilt AI workflows, SDKs, and CI for model ops.</div></div>
          <div class="feature"><h4>Operational Scale</h4><div class="muted">Policy enforcement, observability, and governance at scale.</div></div>
        </div>

        <div class="trust" aria-hidden="true">
          <!-- Replace with real logos -->
          <img alt="Partner" src="/assets/logos/logo1.svg" />
          <img alt="Partner" src="/assets/logos/logo2.svg" />
          <img alt="Partner" src="/assets/logos/logo3.svg" />
        </div>
      </section>

      <aside class="panel" aria-labelledby="waitlist-title">
        <h2 id="waitlist-title" style="margin:0 0 12px">Get Early Access</h2>
        <form id="waitlistForm" action="#" onsubmit="return submitForm(event)" aria-describedby="waitlist-note">
          <input id="email" type="email" placeholder="work@company.com" required />
          <select id="companySize" aria-label="Company size">
            <option value="">Company size</option>
            <option value="1-50">1–50</option>
            <option value="51-250">51–250</option>
            <option value="251-1000">251–1000</option>
            <option value="1000+">1000+</option>
          </select>
          <button class="btn-primary" type="submit">Join Waitlist</button>
        </form>
        <div id="msg" class="muted" aria-live="polite"></div>
        <div id="waitlist-note" class="muted" style="margin-top:12px">We’ll only email launch updates. No spam. Early access prioritized by company fit.</div>
      </aside>
    </div>
  </main>

  <script>
    // Countdown (simple)
    (function(){
      const target = new Date('2026-06-14T00:00:00Z').getTime();
      function tick(){
        const now = Date.now();
        const diff = Math.max(0, target - now);
        const days = Math.floor(diff / (24*60*60*1000));
        const hours = Math.floor((diff % (24*60*60*1000)) / (60*60*1000));
        const mins = Math.floor((diff % (60*60*1000)) / (60*1000));
        const secs = Math.floor((diff % (60*1000)) / 1000);
        // optional: display somewhere or log
      }
      tick(); setInterval(tick,1000);
    })();

    async function submitForm(e){
      e && e.preventDefault();
      const email = document.getElementById('email').value.trim();
      const size = document.getElementById('companySize').value;
      const msg = document.getElementById('msg');
      if(!email){ msg.textContent='Please enter a valid work email.'; return false; }
      msg.textContent='Saving...';
      try {
        const res = await fetch('/api/launching-soon/subscribe', {
          method:'POST',
          headers:{'Content-Type':'application/json'},
          body: JSON.stringify({ email, companySize: size })
        });
        const j = await res.json();
        if(j.ok){
          msg.textContent='Thanks — we’ll be in touch with early access details.';
          // analytics
          if(window.umami) umami('track','waitlist_submitted',{email:email});
        } else {
          msg.textContent='Could not save email. Try again.';
        }
      } catch(err){
        msg.textContent='Network error. Try again later.';
      }
      return false;
    }

    document.getElementById('join-waitlist').addEventListener('click', function(){ document.getElementById('email').focus(); });
  </script>
</body>
</html>
